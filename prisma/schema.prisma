generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Grupo {
  id              String     @id @default(cuid())
  nombre          String     @unique
  color           String     @default("#10B981")
  visibilidad     String     @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  rolesPermitidos String[]   // e.g. ["ADMIN", "OBRAS"]
  capas           Capa[]
  subGrupos       SubGrupo[]
}

model SubGrupo {
  id        String   @id @default(cuid())
  nombre    String
  color     String   @default("#10B981")
  grupoId   String
  grupo     Grupo    @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  capas     Capa[]
}

model Capa {
  id              String    @id @default(cuid())
  nombre          String
  tipo            String    // "geojson", "kml", "maphub"
  color           String    @default("#10B981")
  icono           String?   // Para guardar el nombre del icono de Lucide (ej: "MapPin")
  datosGeo        String    // Guardando JSON string de los datos GeoJSON
  visibilidad     String    @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  rolesPermitidos String[]  // e.g. ["ADMIN", "VECINO"]
  grupoId         String?
  grupo           Grupo?    @relation(fields: [grupoId], references: [id])
  subGrupoId      String?
  subGrupo        SubGrupo? @relation(fields: [subGrupoId], references: [id], onDelete: SetNull)
  creadoEn        DateTime  @default(now())
  actualizadoEn   DateTime  @updatedAt
}

model Usuario {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String   @unique
  nombre      String?
  rol         String   @default("PENDIENTE") // "SUPER_ADMIN", "ADMINISTRADOR", "USUARIO", "PENDIENTE"
  creadoEn    DateTime @default(now())
}

model LineaTransporte {
  id            String   @id @default(cuid())
  nombre        String
  numero        String?
  color         String   @default("#E53E3E")
  descripcion   String?
  categoria     String   @default("NACIONAL")   // NACIONAL | PROVINCIAL | MUNICIPAL
  subcategoria  String?                          // ramal, e.g. "Ramal A"
  sentido       String?                          // IDA | VUELTA | null
  activo        Boolean  @default(true)
  datosGeo      String
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model SolicitudDispositivo {
  id                String    @id @default(cuid())
  nombre            String
  email             String
  deviceFingerprint String?
  deviceInfo        String?
  ipAddress         String?
  estado            String    @default("PENDIENTE")
  customToken       String?
  creadoEn          DateTime  @default(now())
  revisadoEn        DateTime?
}

model DispositivoBloqueado {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  motivo      String?
  email       String?
  creadoEn    DateTime @default(now())
}

model RutaTransporte {
  id                String   @id @default(cuid())
  // Identificación de la solicitud
  numeroSolicitud   String
  idSolicitudWeb    String?
  fechaCreacion     String?
  // Solicitante
  nombreSolicitante String
  empresaSolicitante String?
  cuilCuit          String?
  emailSolicitante  String?
  telefonoSolicitante String?
  // Vehículo
  patente           String?
  tipoVehiculo      String?
  pesoToneladas     Float?
  cargaPeligrosa    Boolean  @default(false)
  tipoCarga         String?
  largoVehiculo     String?
  anchoVehiculo     String?
  alturaVehiculo    String?
  cantidadEjes      Int?
  aseguradora       String?
  nroSeguro         String?
  // Recorrido
  calles            String?
  origenDireccion   String?
  origenLocalidad   String?
  origenPartido     String?
  origenNombre      String?
  destinoDireccion  String?
  destinoLocalidad  String?
  destinoPartido    String?
  destinoNombre     String?
  frecuencia        String?
  horario           String?
  observaciones     String?
  // Vigencia y estado
  vigenciaDesde     String?
  vigenciaHasta     String?
  estado            String   @default("PENDIENTE")
  activo            Boolean  @default(true)
  // GeoJSON
  datosGeo          String
  creadoEn          DateTime @default(now())
}
